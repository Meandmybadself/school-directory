{
  "name": "@sd/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:migrate:local": "wrangler d1 migrations apply school-directory --local",
    "db:migrate:remote": "wrangler d1 migrations apply school-directory --remote",
    "db:seed:local": "wrangler d1 execute school-directory --local --file=./seed/dev-seed.sql"
  },
  "dependencies": {
    "@sd/shared": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
